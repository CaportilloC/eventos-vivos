# EventosVivos — Local Development Environment
#
# Copy this file to .env and adjust values as needed.
# NEVER commit .env or real secrets to version control.
#
MSSQL_SA_PASSWORD=ChangeMe_StrongPassword123!
#
# Docker SQL Server connection string shape:
# Server=localhost,1433;Database=EventosVivosDb;User Id=sa;Password=<MSSQL_SA_PASSWORD>;TrustServerCertificate=True;Encrypt=False
#
# DBeaver / other SQL client connection:
#   Host: localhost
#   Port: 1433
#   Database: EventosVivosDb
#   Username: sa
#   Password: value of MSSQL_SA_PASSWORD in your local .env
#   Driver: Microsoft SQL Server (jdbc:sqlserver://localhost:1433;database=EventosVivosDb;trustServerCertificate=true)
#
# ═══════════════════════════════════════════════════════════════════════════
# Docker commands:
#   Start:  docker compose -f docker/docker-compose.yml up -d
#   Stop:   docker compose -f docker/docker-compose.yml down
#   Logs:   docker compose -f docker/docker-compose.yml logs -f sqlserver
#   Reset:  docker compose -f docker/docker-compose.yml down -v
# ═══════════════════════════════════════════════════════════════════════════
